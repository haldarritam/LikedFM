// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Track {
  id                Int       @id @default(autoincrement())
  artist            String
  title             String
  album             String?
  lastfm_url        String?
  album_art_url     String?
  status            String    @default("pending") // pending | downloading | downloaded | failed | ignored
  youtube_url       String?
  youtube_video_id  String?
  file_path         String?
  download_error    String?
  retry_count       Int       @default(0) // Number of retry attempts
  source            String?   // "loved" | "album" | "playlist"
  album_name        String?   // populated when source is "album"
  playlist_name     String?   // populated when source is "playlist"
  requested_at      DateTime?
  downloaded_at     DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@unique([artist, title])
}

model SyncLog {
  id               Int      @id @default(autoincrement())
  synced_at        DateTime @default(now())
  tracks_found     Int      @default(0)
  tracks_added     Int      @default(0)
  tracks_downloaded Int     @default(0)
  tracks_failed    Int      @default(0)
  loved_count      Int      @default(0)
  album_count      Int      @default(0)
  playlist_count   Int      @default(0)
}

model Settings {
  id                          Int     @id @default(1)
  lastfm_api_key              String?
  lastfm_secret               String?
  lastfm_username             String?
  sync_interval               Int     @default(360) // minutes
  sync_loved                  Boolean @default(true)
  music_output_dir            String  @default("/music")
  audio_format                String  @default("mp3")
  audio_quality               String  @default("320k")
  max_concurrent_downloads    Int     @default(2)
  search_preference           String  @default("auto")
  sync_albums                 Boolean @default(true)
  sync_playlists              Boolean @default(true)
  scan_interval               Int     @default(10)
  max_retries                 Int     @default(3) // Max retry attempts for failed downloads
  updated_at                  DateTime @updatedAt
}

model AlbumBookmark {
  id        Int      @id @default(autoincrement())
  artist    String
  album     String
  added_at  DateTime @default(now())

  @@unique([artist, album])
}
