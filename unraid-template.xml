<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>Discbox</Name>
  <Repository>haldarritam/discbox:latest</Repository>
  <Registry>https://hub.docker.com/r/haldarritam/discbox</Registry>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Support>https://github.com/haldarritam/Discbox/issues</Support>
  <Project>https://github.com/haldarritam/Discbox</Project>
  <Category>Music:</Category>
  <WebUI>http://[IP]:[PORT:8767]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/haldarritam/Discbox/main/unraid-template.xml</TemplateURL>
  <Icon>https://cdn-icons-png.flaticon.com/512/3844/3844724.png</Icon>
  <Description>
    Discbox is a self-hosted music automation app that syncs your loved tracks, saved albums, and playlists from Deezer (and optionally Last.fm) and automatically downloads them from YouTube via yt-dlp. Files are saved in a Navidrome-compatible folder structure with full metadata embedded.
  </Description>

  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>8767</HostPort>
        <ContainerPort>8767</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>

  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/discbox</HostDir>
      <ContainerDir>/app/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/Media/music</HostDir>
      <ContainerDir>/music</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>

  <Environment>
    <Variable>
      <Name>AUDIO_FORMAT</Name>
      <Value>mp3</Value>
      <Description>Audio format: mp3 | flac | opus | m4a</Description>
      <Display>always</Display>
      <Required>false</Required>
    </Variable>
    <Variable>
      <Name>AUDIO_QUALITY</Name>
      <Value>320k</Value>
      <Description>Audio quality: 128k | 192k | 256k | 320k</Description>
      <Display>always</Display>
      <Required>false</Required>
    </Variable>
    <Variable>
      <Name>MAX_CONCURRENT_DOWNLOADS</Name>
      <Value>2</Value>
      <Description>Parallel downloads (1-5)</Description>
      <Display>always</Display>
      <Required>false</Required>
    </Variable>
    <Variable>
      <Name>SYNC_INTERVAL</Name>
      <Value>360</Value>
      <Description>Sync interval in minutes (default: 360 = 6 hours)</Description>
      <Display>always</Display>
      <Required>false</Required>
    </Variable>
  </Environment>

  <Labels></Labels>
  <Config Name="Config Path" Target="/app/config" Default="/mnt/user/appdata/discbox" Mode="rw" Description="Database and settings storage" Type="Path" Display="always" Required="true" Mask="false" />
  <Config Name="Music Path" Target="/music" Default="/mnt/user/Media/music" Mode="rw" Description="Music library path for downloaded tracks" Type="Path" Display="always" Required="true" Mask="false" />
  <Config Name="Port" Target="8767" Default="8767" Mode="tcp" Description="Web UI port" Type="Port" Display="always" Required="true" Mask="false" />
  <Config Name="Audio Format" Target="AUDIO_FORMAT" Default="mp3" Mode="" Description="Download format: mp3 | flac | opus | m4a" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Audio Quality" Target="AUDIO_QUALITY" Default="320k" Mode="" Description="Audio bitrate: 128k | 192k | 256k | 320k" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Max Concurrent Downloads" Target="MAX_CONCURRENT_DOWNLOADS" Default="2" Mode="" Description="Parallel downloads (1-5)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Sync Interval (minutes)" Target="SYNC_INTERVAL" Default="360" Mode="" Description="How often to sync in minutes" Type="Variable" Display="always" Required="false" Mask="false" />
</Container>
